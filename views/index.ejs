<!DOCTYPE html>
<html lang="en">
<head>
<meta name="author" content="sui">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="language" content="English">
<meta name="description" content="Legacy Tracker is Legacy Minecraft Server tracking panel">
<meta name="title" content="Legacy Tracker">
<meta name="theme-color" content="#131313">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.6.0/css/font-awesome.min.css" />
<link rel="stylesheet" href="assets/style.css?v=<%= process.env.ASSETV %>">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/clipboard@2.0.10/dist/clipboard.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@sweetalert2/theme-dark@5/dark.css" />
<%- include('../partials/head') %>
<title>Legacy Tracker</title>
<% const defaultIcon = 'iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAQAAAC1+jfqAAAAIklEQVR42mNgGAWjYBSMglEwCkYwGJiZGBgYFjAADEwIADg8T9ISWk0oAAAAASUVORK5CYII=' %>
</head>
<body>
<%- include('../partials/nav') %>
<div class="c m">
  <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
    <div>
      <h2>Legacy Tracker</h2>
    </div>
    <div>
      <span type="button" id="toggle" class="btn btn-outline-primary btn-sm">Hide Chart</span>
    </div>
  </div>

  <div class="stats mb-3"></div>

  <div class="chart mb-4">
    <div class="card bg-dark">
      <div class="card-header">Players Overtime across servers</div>
      <div class="card-body h-100 d-flex align-items-center justify-content-center">
        <div class="serv position-relative w-100">
          <canvas id="myChart"></canvas>
          <div class="chart-empty-message small text-muted text-center d-none">No servers selected for the chart.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="chart-mode-switch d-flex align-items-center flex-wrap mb-3">
    <span class="text-muted mr-2 small">Chart mode:</span>
    <div class="btn-group btn-group-toggle" role="group">
      <button type="button" class="btn btn-outline-light btn-sm chart-mode-btn active" data-mode="players">Players over time</button>
      <button type="button" class="btn btn-outline-light btn-sm chart-mode-btn" data-mode="average">Average per server</button>
    </div>
  </div>

  <div class="chart-controls d-flex flex-wrap mb-3 align-items-center"></div>

  <div class="table-responsive-lg">
    <table id="serversTable" class="table table-bordered table-compact mb-0">
      <thead>
        <tr>
          <th class="text-center text-bold"></th>
          <th class="sort-header text-nowrap" data-sort="name" style="cursor:pointer;">Server <span class="sort-indicator"></span></th>
    <th class="sort-header text-nowrap" data-sort="ip" style="cursor:pointer;">IP <span class="sort-indicator"></span></th>
    <th class="sort-header text-nowrap" data-sort="version" style="cursor:pointer;">Version <span class="sort-indicator"></span></th>
    <th>Description</th>
          <th class="sort-header text-nowrap" data-sort="online" style="cursor:pointer;">Online <span class="sort-indicator"></span></th>
          <th class="sort-header text-nowrap" data-sort="lastPing" style="cursor:pointer;">Last Ping <span class="sort-indicator"></span></th>
          <th class="sort-header text-nowrap" data-sort="peak" style="cursor:pointer;">Peak <span class="sort-indicator"></span></th>
          <th class="sort-header text-nowrap" data-sort="unique" style="cursor:pointer;">Unique <span class="sort-indicator"></span></th>
        </tr>
      </thead>
      <tbody>
        <% data.forEach(element => { %>
          <tr class="item-<%= element.id %>"
              data-id="<%= element.id %>"
              data-name="<%= element.name %>"
              data-ip="<%= element.ip %>"
              data-version="<%= element.version %>"
              data-online="<%= element.online %>"
              data-last-ping="<%= element.lastPing ? element.lastPing : '' %>"
              data-first-ping="<%= element.firstPing ? element.firstPing : '' %>"
              data-peak="<%= element.peak %>"
              data-unique="<%= element.stored %>">
            <td class="icon-cell text-center">
              <div class="icon-stack">
                <img src="data:image/png;base64,<%= element.icon ? element.icon : defaultIcon %>" alt="<%= element.name %>" class="server-icon" data-toggle="tooltip" data-placement="bottom" title="<%= element.name %>">
              </div>
            </td>
            <td class="cl-<%= element.id %>"><a href="server/<%= element.id %>"><%= element.name %></a></td>
            <td class="cl-<%= element.id %>">
              <%= element.ip %>&ensp;<span class="cb-<%= element.id %> fa fa-clipboard copybtn" data-clipboard-text="<%= element.ip %>"></span>
            </td>
            <td><%= element.version %></td>
            <td class="description-cell"><%= element.desc %></td>
            <td><%= element.online %></td>
            <td class="last-ping-cell">
              <span id="lastPing-<%= element.id %>" class="last-ping text-bold"></span><br>
              <small class="text-muted last-ping-time" id="lastPingTime-<%= element.id %>"></small>
            </td>
            <td><%= element.peak %></td>
            <td><%= element.stored %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
  window.legacyServerData = <%- JSON.stringify(data) %>;
</script>
<script src="assets/index.js?v=<%= process.env.ASSETV %>"></script>
<script>
  $(document).ready(function() {
    refreshLastPingLabels();
    getGlobalGraph();
    getStats();
  });
</script>
</body>
</html>
