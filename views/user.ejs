<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
<meta name="author" content="sui">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="language" content="English">
<meta name="description" content="View Player <%= data.player %>">
<meta name="title" content="Legacy Player | <%= data.player %>">
<link rel="canonical" href="https://legacytracker.xyz/user/<%= data.player %>">
<link rel="icon" href="https://skins.legacyminecraft.com/avatars/<%= data.uuid ? data.uuid : '00000000-0000-0000-0000-000000000000' %>?size=128&overlay">
<meta name="theme-color" content="#131313">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.6.0/css/font-awesome.min.css" />
<link rel="stylesheet" href="../assets/style.css?v=<%= process.env.ASSETV %>">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/clipboard@2.0.10/dist/clipboard.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
<%- include('../partials/head') %>
<title>Legacy Player | <%= data.player %></title>
</head>
<body>
<%- include('../partials/nav') %>
<div class="c m">
<div class="mb-3">
<h2><strong><%= data.player %></strong> <%- data.isValid ? '\<span data-bs-toggle="tooltip" data-bs-placement="top" title="This account is verified">\<span class="badge bg-success">\<i class="fa fa-check" aria-hidden="true">\</i>\</span>\</span>' : '\<span data-bs-toggle="tooltip" data-bs-placement="top" title="This account is not verified">\<span class="badge bg-danger">\<i class="fa fa-times" aria-hidden="true">\</i>\</span>\</span>' %></h2>
<% if (data.isValid) { %>
    <small><span id="q_uuid"><%= data.uuid %></span>&ensp;<span class="fa fa-clipboard copybtn" data-clipboard-text="<%= data.uuid %>"></span></small>
<% } %>
<div class="user-meta-grid mt-3">
  <div class="user-meta-item">
    <span class="user-meta-label">First Cached</span>
    <strong class="tracker-time" data-ts="<%= data.trackerStats ? data.trackerStats.firstCachedOn : '' %>">Loading...</strong>
  </div>
  <div class="user-meta-item">
    <span class="user-meta-label">Last Cached</span>
    <strong class="tracker-time" data-ts="<%= data.trackerStats ? data.trackerStats.lastCachedOn : '' %>">Loading...</strong>
  </div>
  <div class="user-meta-item">
    <span class="user-meta-label">Servers</span>
    <strong id="trackerServersCount"><%= data.trackerStats ? data.trackerStats.trackedServers : 0 %></strong>
  </div>
  <div class="user-meta-item">
    <span class="user-meta-label">Listed</span>
    <strong id="trackerListedCount"><%= data.trackerStats ? data.trackerStats.listedServers : 0 %></strong>
  </div>
</div>
</div>

<div class="row">
<div class="col-lg-4 mb-3">
<div class="card bg-dark">
    <div id="playerModelLoading" class="section-loading"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Loading player model...</div>
    <img id="playerImg" class="justify-content-center align-items-center">
    <canvas id="player" class="justify-content-center align-items-center"></canvas>
    <% if (data.hasRetroMc && data.uuid) { %>
    <div class="card-body pt-2">
      <a class="btn btn-sm btn-outline-info w-100" href="https://statistics.retromc.org/player/<%= data.uuid %>" target="_blank" rel="noopener noreferrer">RetroMC Statistics</a>
    </div>
    <% } %>
</div>



</div>  
<div class="col-lg-8">
    <div class="d-flex justify-content-end mb-2">
      <span id="playerServersLoading" class="small text-muted me-3"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Loading server entries...</span>
      <div class="form-check form-check-inline mb-0">
        <input class="form-check-input" type="checkbox" id="showInactivePlayerToggle">
        <label class="form-check-label small text-muted" for="showInactivePlayerToggle">Show inactive</label>
      </div>
    </div>
    <div class="card bg-dark user-servers-card">
    <div class="table-responsive user-servers-wrap">
<table id="playerServersTable" class="table table-bordered table-compact mb-0">
<thead>
<tr>
<th class="text-center text-bold"></th>
<th>Server</th>
<th>First Seen</th>
<th>Last Seen</th>
</tr>
</thead>
<tbody>

<% data.servers.forEach((element, key) => { %>
<tr data-is-active="<%= element.isActive ? 1 : 0 %>" class="<%= element.isActive ? '' : 'inactive-server-row' %>">
    <td class="icon-cell text-center">
      <div class="icon-stack">
        <% if (element.server_icon) { %>
          <img src="data:image/png;base64,<%= element.server_icon %>" alt="<%= element.server %>" class="img-fluid server-icon" data-bs-toggle="tooltip" data-bs-placement="bottom" title="<%= element.server %>">
        <% } %>
      </div>
    </td>
    <td>
    <h4>
      <% if (element.isActive) { %>
        <a href="../server/<%= element.server_id %>"><%= element.server %></a>
      <% } else { %>
        <span class="inactive-server-name"><%= element.server %></span>
      <% } %>
    </h4>
    </td>
    <td><p class="first" data-ts="<%= element.date %>">Loading...</p></td>
    <td><p class="last" data-ts="<%= element.last_date %>">Loading...</p></td>
</tr>
<% }) %>
</tbody>
</table>
</div>
</div>
</div>
</div>
<%- include('../partials/footer') %>
<script src="../assets/skinview3d.bundle.js"></script>
<script src="../assets/index.js?v=<%= process.env.ASSETV %>"></script>
<script>

    let first = $(".first");
    let last = $(".last");

    $('.first').each(function(index, element) {
    const ts = Number($(this).data("ts")) || 0;
    if (!ts) {
      $(this).text("Unknown").show();
      return;
    }
    $(this).text(moment.unix(ts).format("lll")).attr("title", moment.unix(ts).fromNow()).show();
    });

    $('.last').each(function(index, element) {
    const ts = Number($(this).data("ts")) || 0;
    if (!ts) {
      $(this).text("Unknown").show();
      return;
    }
    $(this).text(moment.unix(ts).format("lll")).attr("title", moment.unix(ts).fromNow()).show();
    });

    $('.tracker-time').each(function() {
    const ts = Number($(this).data('ts')) || 0;
    if (!ts) {
      $(this).text("Unknown");
      return;
    }
    $(this).text(moment.unix(ts).format("lll")).attr("title", moment.unix(ts).fromNow());
    });

    function applyPlayerTableVisibility() {
    const showInactive = $("#showInactivePlayerToggle").is(":checked");
    $("#playerServersTable tbody tr").each(function() {
      const isActive = String($(this).data("is-active")) === "1";
      const shouldShow = isActive || showInactive;
      $(this).toggle(shouldShow);
    });
    }

    $("#showInactivePlayerToggle").on("change", applyPlayerTableVisibility);
    applyPlayerTableVisibility();
    $("#playerServersLoading").addClass("d-none");

    showPlayerModel(
      $("#q_uuid").text(),
      <%- JSON.stringify(data.player || "") %>,
      <%- JSON.stringify(Boolean(data.isValid)) %>
    );

    $("#playerImg").on("load", function() {
      $("#playerModelLoading").addClass("d-none");
    });
    setTimeout(function() {
      $("#playerModelLoading").addClass("d-none");
    }, 900);
</script>

</body>
</html>
